# Root .gitignore - MusicDB Project

# ============================================
# Environment Variables & Secrets
# ============================================
.env
.env.*
!.env.example

# ============================================
# Dependencies
# ============================================
node_modules/
npm-debug.log*
yarn-error.log*
pnpm-error.log*

# ============================================
# Build & Distribution
# ============================================
dist/
build/
.next/
out/

# ============================================
# IDE & Editors
# ============================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# Logs & Debug
# ============================================
*.log
logs/
debug*.js
debug_log.txt
debug_result.json
start.log
